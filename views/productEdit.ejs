<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Product</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- NAV -->
    <nav>
        <div class="nav-inner">
            <a href="/" class="nav-brand">UYGUN MARKETS</a>
            <div class="nav-links">
                <a href="/products">Browse Deals</a>
                <% if (user) { %>
                    <% if (user.type === 'market') { %>
                        <a href="/dashboard" class="btn-primary">Dashboard</a>
                    <% } else { %>
                        <a href="/cart" class="btn-primary">Cart</a>
                    <% } %>
                    <form action="/logout" method="POST">
                        <button type="submit" class="nav-logout">Log out</button>
                    </form>
                <% } else { %>
                    <a href="/login">Log in</a>
                    <a href="/register" class="btn-primary">Get Started</a>
                <% } %>
            </div>
        </div>
    </nav>

    <%
        const expDate = new Date(product.expirationDate);
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        const daysLeft = Math.ceil((expDate - today) / (1000 * 60 * 60 * 24));
        const urgency = daysLeft <= 2 ? 'urgent' : daysLeft <= 5 ? 'soon' : 'ok';   
    %>

    <!-- PRODUCT DETAIL -->
    <main class="page-main">
        <div class="container">
            <a href="/dashboard" class="back-link">← Back to Dashboard</a>

            <form class="detail-layout" method="post" action="/dashboard/product/<%= product.itemID %>/edit" enctype="multipart/form-data">
                <!-- IMAGE -->
                <div class="detail-image-wrap">
                    <img src="/images/<%= product.image %>" alt="<%= product.name %>" class="detail-image" id="detail-image" />
                    <label for="image" class="btn-secondary" style="display:block; margin-top: 12px; text-align: center; cursor: pointer;">Upload Image</label>
                    <input type="file" id="image" name="image" accept="image/*" style="display: none;"
                    onchange="document.getElementById('detail-image').src = window.URL.createObjectURL(this.files[0])">
                </div>
                <!-- INFO -->
                <div class="detail-info" >
                    <div class="detail-meta-top">
                        <span class="market-tag">🏪 <%= product.marketName %></span>
                        <span class="expiry-tag expiry-<%= urgency %>">
                            <% if (daysLeft === 0) { %>
                                Expires today!
                            <% } else if (daysLeft === 1) { %>
                                1 day left
                            <% } else { %>
                                <%= daysLeft %> days left
                            <% } %>
                        </span>
                    </div>

                    <div class="detail-pricing" style="width: 800px; display: inline-block;">
                        <div class="input-field">
                            <input class="input-border" type="text" name="name" value="" placeholder=" ">
                            <span class="input-info placeholder" style="opacity: 0.8 ;"><%= product.name %> (Name)</span>
                            <span class="input-change-line placeholder"></span>
                        </div>
                        <div class="input-field">
                            <input class="input-border" type="text" name="basePrice" value="" placeholder=" ">
                            <span class="input-info placeholder" style="opacity: 0.8 ;"><%= product.basePrice %> (Price)</span>
                            <span class="input-change-line placeholder"></span>
                        </div>
                        <div class="input-field">
                            <input class="input-border" type="text" name="discountPrice" value="" placeholder=" ">
                            <span class="input-info placeholder" style="opacity: 0.8 ;"><%= product.discountPrice %> (Discounted Price)</span>
                            <span class="input-change-line placeholder"></span>
                        </div>
                         <div class="input-field">
                            <input class="input-border" type="text" name="stock" value="" placeholder=" ">
                            <span class="input-info placeholder" style="opacity: 0.8 ;"><%= product.stock %> (Stock)</span>
                            <span class="input-change-line placeholder"></span>
                        </div>
                         <div class="input-field">
                            <input class="input-border" type="date" name="expirationDate" value="<%= formatDateForInput(expDate) %>" placeholder=" ">
                            <span class="input-info placeholder" style="opacity: 0.8 ;">Expiry Date</span>
                        </div>
                    </div>
                    <button type="submit" class="btn-primary" style="margin-bottom: 10px; max-width: 500px">Save</button>
                </div>
            </form>
        </div>
    </main>

    <%- include('partials/_footer') %>
</body>
</html>