<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Product</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- NAV -->
    <nav>
        <div class="nav-inner">
            <a href="/" class="nav-brand">UYGUN MARKETS</a>
            <div class="nav-links">
                <a href="/products">Browse Deals</a>
                <% if (user) { %>
                    <% if (user.type === 'market') { %>
                        <a href="/dashboard" class="btn-primary">Dashboard</a>
                    <% } else { %>
                        <a href="/cart" class="btn-primary">Cart</a>
                    <% } %>
                    <form action="/logout" method="POST">
                        <button type="submit" class="nav-logout">Log out</button>
                    </form>
                <% } else { %>
                    <a href="/login">Log in</a>
                    <a href="/register" class="btn-primary">Get Started</a>
                <% } %>
            </div>
        </div>
    </nav>

    <%
        const expDate = new Date(product.expirationDate);
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        const daysLeft = Math.ceil((expDate - today) / (1000 * 60 * 60 * 24));
        const urgency = daysLeft <= 2 ? 'urgent' : daysLeft <= 5 ? 'soon' : 'ok';
        const savings = Math.round(((product.basePrice - product.discountPrice) / product.basePrice) * 100);
    %>

    <!-- PRODUCT DETAIL -->
    <main class="page-main">
        <div class="container">
            <a href="/products" class="back-link">← Back to deals</a>

            <form class="detail-layout" method="post" action="/dashboard/product/<%= product.id %>/edit" enctype="multipart/form-data">
                <!-- IMAGE -->
                <div class="detail-image-wrap">
                    <img src="/images/<%= product.image %>" alt="<%= product.name %>" class="detail-image" />
                    <span class="discount-badge detail-badge">-<%= savings %>%</span>
                    <button type="button" class="btn-secondary detail-image-wrap">Upload Image</button>
                </div>

                <!-- INFO -->
                <div class="detail-info" >
                    <div class="detail-meta-top">
                        <span class="market-tag">🏪 <%= product.marketName %></span>
                        <span class="expiry-tag expiry-<%= urgency %>">
                            <% if (daysLeft === 0) { %>
                                Expires today!
                            <% } else if (daysLeft === 1) { %>
                                1 day left
                            <% } else { %>
                                <%= daysLeft %> days left
                            <% } %>
                        </span>
                    </div>

                    <div class="detail-pricing" style="width: 700px; display: inline-block;">
                        <div class="input-field">
                            <input style="border: 1px solid var(--green-dark);" type="text" name="prodName" value="" placeholder=" ">
                            <span class="input-info placeholder" style="opacity: 0.8 ;"><%= product.name %> (Name)</span>
                            <span class="input-change-line placeholder"></span>
                        </div>
                        <div class="input-field">
                            <input style="border: 1px solid var(--green-dark);" type="text" name="prodPrice" value="" placeholder=" ">
                            <span class="input-info placeholder" style="opacity: 0.8 ;"><%= product.basePrice %> (Price)</span>
                            <span class="input-change-line placeholder"></span>
                        </div>
                        <div class="input-field">
                            <input style="border: 1px solid var(--green-dark);" type="text" name="prodDiscPrice" value="" placeholder=" ">
                            <span class="input-info placeholder" style="opacity: 0.8 ;"><%= product.discountPrice %> (Discounted Price)</span>
                            <span class="input-change-line placeholder"></span>
                        </div>
                        <div class="input-field">
                            <input style="border: 1px solid var(--green-dark);" type="text" name="district" value="" placeholder=" ">
                            <span class="input-info placeholder" style="opacity: 0.8 ;"><%= product.district %> (District)</span>
                            <span class="input-change-line placeholder"></span>
                        </div>
                         <div class="input-field">
                            <input style="border: 1px solid var(--green-dark);" type="text" name="city" value="" placeholder=" ">
                            <span class="input-info placeholder" style="opacity: 0.8 ;"><%= product.city %> (City)</span>
                            <span class="input-change-line placeholder"></span>
                        </div>
                         <div class="input-field">
                            <input style="border: 1px solid var(--green-dark);" type="text" name="prodDiscPrice" value="" placeholder=" ">
                            <span class="input-info placeholder" style="opacity: 0.8 ;"><%= product.stock %> (Stock)</span>
                            <span class="input-change-line placeholder"></span>
                        </div>
                         <div class="input-field">
                            <input style=" border: 1px solid var(--green-dark);" type="text" name="prodDiscPrice" value="" placeholder=" ">
                            <span class="input-info placeholder" style="opacity: 0.8 ;">
                                <%= expDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) %> (Expiry)
                            </span>
                            <span class="input-change-line placeholder"></span>
                        </div>
                    </div>
                    <button type="submit" class="btn-primary" style="margin-bottom: 10px;">Save</button>
                </div>
            </form>
        </div>
    </main>

    <%- include('partials/_footer') %>
</body>
</html>